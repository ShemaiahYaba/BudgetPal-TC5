<%- include('partials/head', { title: 'Profile' }) %>
<%- include('partials/nav') %>

<div class="max-w-5xl mx-auto px-5">
  <div class="pt-7 pb-5">
    <div class="text-2xl font-bold">Profile</div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <!-- Account info -->
    <div class="bg-white border border-slate-200 rounded-xl p-6 shadow-sm">
      <h2 class="text-base font-semibold mb-5">Account Info</h2>
      <div id="profile-alert"   class="hidden p-3 rounded-lg text-sm mb-4 bg-red-100 text-red-800 border border-red-300"></div>
      <div id="profile-success" class="hidden p-3 rounded-lg text-sm mb-4 bg-emerald-100 text-emerald-800 border border-emerald-300"></div>
      <div class="mb-4">
        <label class="block text-sm font-medium text-slate-500 mb-1.5">Name</label>
        <input type="text" id="p-name" placeholder="Your name"
          class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm bg-white outline-none" />
      </div>
      <div class="mb-4">
        <label class="block text-sm font-medium text-slate-500 mb-1.5">Email</label>
        <input type="email" id="p-email" disabled
          class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm bg-slate-50 text-slate-400 outline-none cursor-not-allowed" />
      </div>
      <div class="mb-5">
        <label class="block text-sm font-medium text-slate-500 mb-1.5">Member since</label>
        <input type="text" id="p-joined" disabled
          class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm bg-slate-50 text-slate-400 outline-none cursor-not-allowed" />
      </div>
      <button id="btn-save-profile" class="px-4 py-2 bg-emerald-500 text-white rounded-lg text-sm font-medium hover:bg-emerald-600 transition-colors cursor-pointer border-none">Save Changes</button>
    </div>

    <!-- Change password -->
    <div class="bg-white border border-slate-200 rounded-xl p-6 shadow-sm">
      <h2 class="text-base font-semibold mb-5">Change Password</h2>
      <div id="pwd-alert"   class="hidden p-3 rounded-lg text-sm mb-4 bg-red-100 text-red-800 border border-red-300"></div>
      <div id="pwd-success" class="hidden p-3 rounded-lg text-sm mb-4 bg-emerald-100 text-emerald-800 border border-emerald-300"></div>
      <div class="mb-4">
        <label class="block text-sm font-medium text-slate-500 mb-1.5">
          New Password <span class="text-slate-400 font-normal">(min 8 characters)</span>
        </label>
        <input type="password" id="p-password" placeholder="••••••••" minlength="8"
          class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm bg-white outline-none" />
      </div>
      <div class="mb-5">
        <label class="block text-sm font-medium text-slate-500 mb-1.5">Confirm Password</label>
        <input type="password" id="p-confirm" placeholder="••••••••" minlength="8"
          class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm bg-white outline-none" />
      </div>
      <button id="btn-save-pwd" class="px-4 py-2 bg-emerald-500 text-white rounded-lg text-sm font-medium hover:bg-emerald-600 transition-colors cursor-pointer border-none">Update Password</button>
    </div>
  </div>
</div>

<script src="/js/profile.js"></script>
</body></html>
