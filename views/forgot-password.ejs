<%- include('partials/head', { title: 'Forgot Password' }) %>
<div class="min-h-screen flex items-center justify-center p-5">
  <div class="w-full max-w-sm bg-white border border-slate-200 rounded-xl p-8 shadow-sm">
    <h1 class="text-2xl font-bold mb-1">Forgot password?</h1>
    <p class="text-slate-500 text-sm mb-6">Enter your email and we'll send you a reset link.</p>
    <div id="alert"   class="hidden p-3 rounded-lg text-sm mb-4 bg-red-100 text-red-800 border border-red-300"></div>
    <div id="success" class="hidden p-3 rounded-lg text-sm mb-4 bg-emerald-100 text-emerald-800 border border-emerald-300"></div>
    <form id="forgot-form">
      <div class="mb-5">
        <label class="block text-sm font-medium text-slate-500 mb-1.5">Email</label>
        <input type="email" id="email" placeholder="you@example.com" required
          class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm bg-white text-slate-800 outline-none" />
      </div>
      <button type="submit" id="submit-btn"
        class="w-full flex justify-center py-2.5 bg-emerald-500 text-white rounded-lg text-sm font-medium hover:bg-emerald-600 transition-colors cursor-pointer border-none">
        Send Reset Link
      </button>
    </form>
    <p class="text-center mt-4 text-sm text-slate-500">
      Remembered it? <a href="/login" class="text-emerald-500 hover:underline">Back to login</a>
    </p>
  </div>
</div>
<script src="/js/forgot-password.js"></script>
</body></html>
