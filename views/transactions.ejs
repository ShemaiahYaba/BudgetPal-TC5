<%- include('partials/head', { title: 'Transactions' }) %>
<%- include('partials/nav') %>

<div class="max-w-5xl mx-auto px-5">
  <div class="pt-7 pb-5 flex items-center justify-between">
    <div class="text-2xl font-bold">Transactions</div>
    <button id="btn-add" class="inline-flex items-center gap-1.5 px-4 py-2 bg-emerald-500 text-white rounded-lg text-sm font-medium hover:bg-emerald-600 transition-colors cursor-pointer border-none">+ Add</button>
  </div>

  <!-- Filters -->
  <div class="flex flex-wrap gap-2.5 mb-5">
    <select id="f-type"     class="w-auto px-3 py-2 border border-slate-200 rounded-lg text-sm bg-white outline-none">
      <option value="">All types</option>
      <option value="income">Income</option>
      <option value="expense">Expense</option>
    </select>
    <select id="f-category" class="w-auto px-3 py-2 border border-slate-200 rounded-lg text-sm bg-white outline-none flex-1 min-w-36">
      <option value="">All categories</option>
    </select>
    <input type="date" id="f-start" title="From" class="w-auto px-3 py-2 border border-slate-200 rounded-lg text-sm bg-white outline-none" />
    <input type="date" id="f-end"   title="To"   class="w-auto px-3 py-2 border border-slate-200 rounded-lg text-sm bg-white outline-none" />
    <button id="btn-filter" class="px-3 py-2 bg-emerald-500 text-white rounded-lg text-sm font-medium hover:bg-emerald-600 transition-colors cursor-pointer border-none">Filter</button>
    <button id="btn-clear"  class="px-3 py-2 border border-slate-200 text-slate-500 rounded-lg text-sm bg-white hover:bg-slate-50 transition-colors cursor-pointer">Clear</button>
  </div>

  <div class="bg-white border border-slate-200 rounded-xl shadow-sm">
    <div class="overflow-x-auto">
      <table class="w-full border-collapse text-sm">
        <thead>
          <tr>
            <th class="text-left text-xs font-semibold text-slate-500 uppercase tracking-wide px-4 py-3 border-b border-slate-200">Date</th>
            <th class="text-left text-xs font-semibold text-slate-500 uppercase tracking-wide px-4 py-3 border-b border-slate-200">Category</th>
            <th class="text-left text-xs font-semibold text-slate-500 uppercase tracking-wide px-4 py-3 border-b border-slate-200">Type</th>
            <th class="text-left text-xs font-semibold text-slate-500 uppercase tracking-wide px-4 py-3 border-b border-slate-200">Description</th>
            <th class="text-right text-xs font-semibold text-slate-500 uppercase tracking-wide px-4 py-3 border-b border-slate-200">Amount</th>
            <th class="px-4 py-3 border-b border-slate-200"></th>
          </tr>
        </thead>
        <tbody id="tx-body"></tbody>
      </table>
      <p id="no-tx" class="hidden text-slate-500 px-4 py-5 text-center text-sm">No transactions found.</p>
    </div>
  </div>
</div>

<!-- Add/Edit Modal -->
<div id="modal" class="fixed inset-0 bg-black/40 hidden flex items-center justify-center z-50 p-5">
  <div class="bg-white rounded-xl p-7 w-full max-w-md shadow-2xl">
    <h2 id="modal-title" class="text-lg font-semibold mb-5">Add Transaction</h2>
    <div id="modal-alert" class="hidden p-3 rounded-lg text-sm mb-4 bg-red-100 text-red-800 border border-red-300"></div>
    <div class="mb-4">
      <label class="block text-sm font-medium text-slate-500 mb-1.5">Category</label>
      <select id="m-category" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm bg-white outline-none"></select>
    </div>
    <div class="grid grid-cols-2 gap-4">
      <div class="mb-4">
        <label class="block text-sm font-medium text-slate-500 mb-1.5">Type</label>
        <select id="m-type" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm bg-white outline-none">
          <option value="expense">Expense</option>
          <option value="income">Income</option>
        </select>
      </div>
      <div class="mb-4">
        <label class="block text-sm font-medium text-slate-500 mb-1.5">Amount</label>
        <input type="number" id="m-amount" step="0.01" min="0.01" placeholder="0.00"
          class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm bg-white outline-none" />
      </div>
    </div>
    <div class="mb-4">
      <label class="block text-sm font-medium text-slate-500 mb-1.5">Date</label>
      <input type="date" id="m-date" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm bg-white outline-none" />
    </div>
    <div class="mb-5">
      <label class="block text-sm font-medium text-slate-500 mb-1.5">
        Description <span class="text-slate-400 font-normal">(optional)</span>
      </label>
      <input type="text" id="m-desc" placeholder="e.g. Grocery shopping"
        class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm bg-white outline-none" />
    </div>
    <div class="flex justify-end gap-2.5">
      <button id="btn-modal-cancel" class="px-4 py-2 border border-slate-200 text-slate-500 rounded-lg text-sm bg-white hover:bg-slate-50 transition-colors cursor-pointer">Cancel</button>
      <button id="m-save"           class="px-4 py-2 bg-emerald-500 text-white rounded-lg text-sm font-medium hover:bg-emerald-600 transition-colors cursor-pointer border-none">Save</button>
    </div>
  </div>
</div>

<script src="/js/transactions.js"></script>
</body></html>
