<%- include('partials/head', { title: 'Categories' }) %>
<%- include('partials/nav') %>

<div class="max-w-5xl mx-auto px-5">
  <div class="pt-7 pb-5 flex items-center justify-between">
    <div class="text-2xl font-bold">Categories</div>
    <button id="btn-add" class="inline-flex items-center gap-1.5 px-4 py-2 bg-emerald-500 text-white rounded-lg text-sm font-medium hover:bg-emerald-600 transition-colors cursor-pointer border-none">+ Add</button>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <!-- Income -->
    <div class="bg-white border border-slate-200 rounded-xl p-6 shadow-sm">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-base font-semibold">Income</h2>
        <span id="income-count" class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-emerald-100 text-emerald-800">0</span>
      </div>
      <div id="income-list"></div>
      <p id="no-income" class="hidden text-slate-500 text-sm text-center py-3">No income categories yet.</p>
    </div>

    <!-- Expense -->
    <div class="bg-white border border-slate-200 rounded-xl p-6 shadow-sm">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-base font-semibold">Expense</h2>
        <span id="expense-count" class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-red-100 text-red-800">0</span>
      </div>
      <div id="expense-list"></div>
      <p id="no-expense" class="hidden text-slate-500 text-sm text-center py-3">No expense categories yet.</p>
    </div>
  </div>
</div>

<!-- Add / Edit Modal -->
<div id="modal" class="fixed inset-0 bg-black/40 hidden flex items-center justify-center z-50 p-5">
  <div class="bg-white rounded-xl p-7 w-full max-w-md shadow-2xl">
    <h2 id="modal-title" class="text-lg font-semibold mb-5">Add Category</h2>
    <div id="modal-alert" class="hidden p-3 rounded-lg text-sm mb-4 bg-red-100 text-red-800 border border-red-300"></div>
    <div class="mb-4">
      <label class="block text-sm font-medium text-slate-500 mb-1.5">Name</label>
      <input type="text" id="m-name" placeholder="e.g. Groceries"
        class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm bg-white outline-none" />
    </div>
    <div class="mb-5">
      <label class="block text-sm font-medium text-slate-500 mb-1.5">Type</label>
      <select id="m-type" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm bg-white outline-none">
        <option value="expense">Expense</option>
        <option value="income">Income</option>
      </select>
    </div>
    <div class="flex justify-end gap-2.5">
      <button id="btn-modal-cancel" class="px-4 py-2 border border-slate-200 text-slate-500 rounded-lg text-sm bg-white hover:bg-slate-50 transition-colors cursor-pointer">Cancel</button>
      <button id="btn-modal-save"   class="px-4 py-2 bg-emerald-500 text-white rounded-lg text-sm font-medium hover:bg-emerald-600 transition-colors cursor-pointer border-none">Save</button>
    </div>
  </div>
</div>

<script src="/js/categories.js"></script>
</body></html>
