<%- include('partials/head', { title: 'Budgets' }) %>
<%- include('partials/nav') %>

<div class="max-w-5xl mx-auto px-5">
  <div class="pt-7 pb-5 flex items-center justify-between">
    <div>
      <div class="text-2xl font-bold">Budgets</div>
      <div class="text-slate-500 text-sm mt-0.5">Expense categories only</div>
    </div>
    <div class="flex gap-2 items-center">
      <select id="month-select" class="w-auto px-3 py-2 border border-slate-200 rounded-lg text-sm bg-white outline-none"></select>
      <select id="year-select"  class="w-auto px-3 py-2 border border-slate-200 rounded-lg text-sm bg-white outline-none"></select>
      <button id="btn-add" class="inline-flex items-center gap-1.5 px-4 py-2 bg-emerald-500 text-white rounded-lg text-sm font-medium hover:bg-emerald-600 transition-colors cursor-pointer border-none">+ Add</button>
    </div>
  </div>

  <div id="budgets-grid" class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6"></div>
  <p id="no-budgets" class="hidden text-slate-500 text-center text-sm py-8">
    No budgets found for this period. Add one to start tracking.
  </p>
</div>

<!-- Add Modal -->
<div id="modal" class="fixed inset-0 bg-black/40 hidden flex items-center justify-center z-50 p-5">
  <div class="bg-white rounded-xl p-7 w-full max-w-md shadow-2xl">
    <h2 class="text-lg font-semibold mb-5">Add Budget</h2>
    <div id="modal-alert" class="hidden p-3 rounded-lg text-sm mb-4 bg-red-100 text-red-800 border border-red-300"></div>
    <div class="mb-4">
      <label class="block text-sm font-medium text-slate-500 mb-1.5">Expense Category</label>
      <select id="m-category" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm bg-white outline-none"></select>
    </div>
    <div class="grid grid-cols-2 gap-4">
      <div class="mb-4">
        <label class="block text-sm font-medium text-slate-500 mb-1.5">Month</label>
        <select id="m-month" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm bg-white outline-none"></select>
      </div>
      <div class="mb-4">
        <label class="block text-sm font-medium text-slate-500 mb-1.5">Year</label>
        <select id="m-year" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm bg-white outline-none"></select>
      </div>
    </div>
    <div class="mb-5">
      <label class="block text-sm font-medium text-slate-500 mb-1.5">Limit Amount</label>
      <input type="number" id="m-limit" step="0.01" min="0.01" placeholder="e.g. 500.00"
        class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm bg-white outline-none" />
    </div>
    <div class="flex justify-end gap-2.5">
      <button id="btn-modal-cancel" class="px-4 py-2 border border-slate-200 text-slate-500 rounded-lg text-sm bg-white hover:bg-slate-50 transition-colors cursor-pointer">Cancel</button>
      <button id="btn-modal-save"   class="px-4 py-2 bg-emerald-500 text-white rounded-lg text-sm font-medium hover:bg-emerald-600 transition-colors cursor-pointer border-none">Save</button>
    </div>
  </div>
</div>

<!-- Edit Modal -->
<div id="edit-modal" class="fixed inset-0 bg-black/40 hidden flex items-center justify-center z-50 p-5">
  <div class="bg-white rounded-xl p-7 w-full max-w-md shadow-2xl">
    <h2 class="text-lg font-semibold mb-5">Update Budget Limit</h2>
    <div id="edit-alert" class="hidden p-3 rounded-lg text-sm mb-4 bg-red-100 text-red-800 border border-red-300"></div>
    <div class="mb-5">
      <label class="block text-sm font-medium text-slate-500 mb-1.5">New Limit Amount</label>
      <input type="number" id="e-limit" step="0.01" min="0.01"
        class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm bg-white outline-none" />
    </div>
    <div class="flex justify-end gap-2.5">
      <button id="btn-edit-cancel" class="px-4 py-2 border border-slate-200 text-slate-500 rounded-lg text-sm bg-white hover:bg-slate-50 transition-colors cursor-pointer">Cancel</button>
      <button id="btn-edit-save"   class="px-4 py-2 bg-emerald-500 text-white rounded-lg text-sm font-medium hover:bg-emerald-600 transition-colors cursor-pointer border-none">Update</button>
    </div>
  </div>
</div>

<script src="/js/budgets.js"></script>
</body></html>
