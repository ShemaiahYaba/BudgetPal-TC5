              "path": ["reports", "by-category"],
              "query": [
                { "key": "type", "value": "expense" },
                { "key": "month", "value": "3" },
                { "key": "year", "value": "2026" }
              ]
            }
          }
        },
        {
          "name": "GET /reports/monthly",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/reports/monthly", "host": ["{{base_url}}"], "path": ["reports", "monthly"] },
            "description": "Month-by-month overview. Defaults to last 6 months."
          }
        },
        {
          "name": "GET /reports/monthly — By Year",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/reports/monthly?year=2026",
              "host": ["{{base_url}}"],
              "path": ["reports", "monthly"],
              "query": [{ "key": "year", "value": "2026" }]
            }
          }
        },
        {
          "name": "POST /reports/email",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"month\": 3,\n  \"year\": 2026\n}"
            },
            "url": { "raw": "{{base_url}}/reports/email", "host": ["{{base_url}}"], "path": ["reports", "email"] },
            "description": "Sends the report to the authenticated user's email."
          }
        }
      ]
    },
    {
      "name": "Error Tests",
      "item": [
        {
          "name": "No Token — 401",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": { "raw": "{{base_url}}/transactions", "host": ["{{base_url}}"], "path": ["transactions"] }
          }
        },
        {
          "name": "Not Found — 404",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/transactions/00000000-0000-0000-0000-000000000000", "host": ["{{base_url}}"], "path": ["transactions", "00000000-0000-0000-0000-000000000000"] }
          }
        },
        {
          "name": "Unknown Route — 404",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/this-does-not-exist", "host": ["{{base_url}}"], "path": ["this-does-not-exist"] }
          }
        }
      ]
    }
  ]
}
