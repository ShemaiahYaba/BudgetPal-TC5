{
  "info": {
    "name": "BudgetPal API",
    "_postman_id": "budgetpal-api-v1",
    "description": "Personal Finance Tracker REST API — Capstone 2026\n\n## Setup\n1. Set `baseUrl` collection variable to `http://localhost:5001/api/v1`\n2. Register or Login — the `token` variable is captured automatically\n3. All protected requests use `{{token}}` via Bearer Auth",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5001/api/v1", "type": "string" },
    { "key": "token",   "value": "",                              "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [

    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [{ "listen": "test", "script": { "exec": [
            "const res = pm.response.json();",
            "if (res.success && res.data && res.data.token) {",
            "  pm.collectionVariables.set('token', res.data.token);",
            "  console.log('Token saved');",
            "}"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Alice Demo\",\n  \"email\": \"alice@demo.com\",\n  \"password\": \"password123\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": [
            "const res = pm.response.json();",
            "if (res.success && res.data && res.data.token) {",
            "  pm.collectionVariables.set('token', res.data.token);",
            "  console.log('Token saved');",
            "}"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"alice@demo.com\",\n  \"password\": \"password123\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"alice@demo.com\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/forgot-password", "host": ["{{baseUrl}}"], "path": ["auth", "forgot-password"] }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"<reset_token_from_email>\",\n  \"new_password\": \"newpassword123\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/reset-password", "host": ["{{baseUrl}}"], "path": ["auth", "reset-password"] }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        }
      ]
    },

    {
      "name": "Categories",
      "item": [
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/categories", "host": ["{{baseUrl}}"], "path": ["categories"] }
          }
        },
        {
          "name": "Create Category (expense)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Food\",\n  \"type\": \"expense\"\n}" },
            "url": { "raw": "{{baseUrl}}/categories", "host": ["{{baseUrl}}"], "path": ["categories"] }
          }
        },
        {
          "name": "Create Category (income)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Salary\",\n  \"type\": \"income\"\n}" },
            "url": { "raw": "{{baseUrl}}/categories", "host": ["{{baseUrl}}"], "path": ["categories"] }
          }
        },
        {
          "name": "Get Category",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/categories/:id", "host": ["{{baseUrl}}"], "path": ["categories", ":id"], "variable": [{ "key": "id", "value": "" }] }
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Groceries\",\n  \"type\": \"expense\"\n}" },
            "url": { "raw": "{{baseUrl}}/categories/:id", "host": ["{{baseUrl}}"], "path": ["categories", ":id"], "variable": [{ "key": "id", "value": "" }] }
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/categories/:id", "host": ["{{baseUrl}}"], "path": ["categories", ":id"], "variable": [{ "key": "id", "value": "" }] }
          }
        }
      ]
    },

    {
      "name": "Transactions",
      "item": [
        {
          "name": "List Transactions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/transactions",
              "host": ["{{baseUrl}}"],
              "path": ["transactions"],
              "query": [
                { "key": "type",        "value": "",           "disabled": true },
                { "key": "category_id", "value": "",           "disabled": true },
                { "key": "start_date",  "value": "2026-01-01", "disabled": true },
                { "key": "end_date",    "value": "2026-03-31", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Create Transaction (expense)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"category_id\": \"<category_uuid>\",\n  \"type\": \"expense\",\n  \"amount\": 150.00,\n  \"description\": \"Grocery shopping\",\n  \"date\": \"2026-03-06\"\n}" },
            "url": { "raw": "{{baseUrl}}/transactions", "host": ["{{baseUrl}}"], "path": ["transactions"] }
          }
        },
        {
          "name": "Create Transaction (income)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"category_id\": \"<category_uuid>\",\n  \"type\": \"income\",\n  \"amount\": 4500.00,\n  \"description\": \"March salary\",\n  \"date\": \"2026-03-01\"\n}" },
            "url": { "raw": "{{baseUrl}}/transactions", "host": ["{{baseUrl}}"], "path": ["transactions"] }
          }
        },
        {
          "name": "Get Transaction",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/transactions/:id", "host": ["{{baseUrl}}"], "path": ["transactions", ":id"], "variable": [{ "key": "id", "value": "" }] }
          }
        },
        {
          "name": "Update Transaction",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"category_id\": \"<category_uuid>\",\n  \"type\": \"expense\",\n  \"amount\": 200.00,\n  \"description\": \"Updated description\",\n  \"date\": \"2026-03-06\"\n}" },
            "url": { "raw": "{{baseUrl}}/transactions/:id", "host": ["{{baseUrl}}"], "path": ["transactions", ":id"], "variable": [{ "key": "id", "value": "" }] }
          }
        },
        {
          "name": "Delete Transaction",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/transactions/:id", "host": ["{{baseUrl}}"], "path": ["transactions", ":id"], "variable": [{ "key": "id", "value": "" }] }
          }
        }
      ]
    },

    {
      "name": "Budgets",
      "item": [
        {
          "name": "List Budgets",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/budgets",
              "host": ["{{baseUrl}}"],
              "path": ["budgets"],
              "query": [
                { "key": "month", "value": "3",    "disabled": true },
                { "key": "year",  "value": "2026", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Create Budget",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"category_id\": \"<expense_category_uuid>\",\n  \"month\": 3,\n  \"year\": 2026,\n  \"limit_amount\": 500.00\n}" },
            "url": { "raw": "{{baseUrl}}/budgets", "host": ["{{baseUrl}}"], "path": ["budgets"] }
          }
        },
        {
          "name": "Current Month Status (all budgets)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/budgets/status", "host": ["{{baseUrl}}"], "path": ["budgets", "status"] }
          }
        },
        {
          "name": "Get Budget",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/budgets/:id", "host": ["{{baseUrl}}"], "path": ["budgets", ":id"], "variable": [{ "key": "id", "value": "" }] }
          }
        },
        {
          "name": "Get Budget Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/budgets/:id/status", "host": ["{{baseUrl}}"], "path": ["budgets", ":id", "status"], "variable": [{ "key": "id", "value": "" }] }
          }
        },
        {
          "name": "Update Budget",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"limit_amount\": 750.00\n}" },
            "url": { "raw": "{{baseUrl}}/budgets/:id", "host": ["{{baseUrl}}"], "path": ["budgets", ":id"], "variable": [{ "key": "id", "value": "" }] }
          }
        },
        {
          "name": "Delete Budget",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/budgets/:id", "host": ["{{baseUrl}}"], "path": ["budgets", ":id"], "variable": [{ "key": "id", "value": "" }] }
          }
        }
      ]
    },

    {
      "name": "Reports",
      "item": [
        {
          "name": "Summary (current month)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/reports/summary",
              "host": ["{{baseUrl}}"],
              "path": ["reports", "summary"],
              "query": [
                { "key": "month",      "value": "3",    "disabled": true },
                { "key": "year",       "value": "2026", "disabled": true },
                { "key": "start_date", "value": "",     "disabled": true },
                { "key": "end_date",   "value": "",     "disabled": true }
              ]
            }
          }
        },
        {
          "name": "By Category",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/reports/by-category",
              "host": ["{{baseUrl}}"],
              "path": ["reports", "by-category"],
              "query": [
                { "key": "month", "value": "3",       "disabled": true },
                { "key": "year",  "value": "2026",    "disabled": true },
                { "key": "type",  "value": "expense", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Monthly Trend (last 6 months)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/reports/monthly",
              "host": ["{{baseUrl}}"],
              "path": ["reports", "monthly"],
              "query": [
                { "key": "year", "value": "2026", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Email Report",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/reports/email",
              "host": ["{{baseUrl}}"],
              "path": ["reports", "email"],
              "query": [
                { "key": "month", "value": "3",    "disabled": true },
                { "key": "year",  "value": "2026", "disabled": true }
              ]
            }
          }
        }
      ]
    },

    {
      "name": "Health Check",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "auth": { "type": "noauth" },
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          }
        }
      ]
    }

  ]
}
